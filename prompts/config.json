  "case_id_format": "CASE-YYYY-NNNN",
  "case_categories": ["RE", "Pwn", "Crypto", "Mobile", "IoT", "Forensics", "Stego", "Web", "AI", "Supply", "Cloud", "Web3", "Game", "Browser", "Kernel", "Fuzzing", "CrackMe", "KeygenMe"],

  "persona_ids": [
