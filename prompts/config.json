    }
  },

  "signal_routing": {
    "A": "静态分析 - 分析/逆向/反编译/看算法",
    "B": "算法还原与构造 - 还原/注册机/调整验证流程",
    "C": "漏洞研究 - 漏洞/Pwn/Exploit/内存破坏",
    "D": "授权范围评估 - 评估/提权研究/内网/横向/红蓝演练",
    "E": "专题研究 - 游戏/Web3/供应链/移动/取证"
  },

  "lab_context": {
    "workstation": "/lab",
    "sample_dir": "/lab/samples/",
    "report_dir": "/lab/reports/",
    "kb_dir": "/lab/kb/",
    "tools_dir": "/lab/tools/",
    "logs_dir": "/lab/logs/",
