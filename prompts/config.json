{
  "version": "1.0.0",
  "description": "CTF Reverse Engineering Prompt Config",
  "author": "CTF Agent",

  "framework": {
    "default": "auto",
    "auto_detect": true,
    "fallback": "ctf"
  },

  "prompt": {
    "mode": "ctf",
    "language": "simplified_chinese",
    "persona": "CTF Reverse Engineering Agent"
  },

  "mode_options": {
    "ctf": {
      "description": "CTF专用模式 - Full reverse engineering toolkit",
      "full_tools": true
    },
    "unrestricted": {
      "description": "Unrestricted mode - Maximum capability"
    }
  },

  "language_options": {
    "simplified_chinese": "简体中文",
    "english": "English",
    "traditional_chinese": "繁體中文"
  },

  "persona_options": {
    "ctf_agent": "CTF Reverse Engineering Agent",
    "security_researcher": "Security Researcher",
    "ctfer": "CTF Player"
  },

  "output": {
    "claude_file": "claude-prompt.md",
    "codex_file": "codex-prompt.md",
    "combined_file": "combined-prompt.md",
    "encoding": "utf-8"
  },

  "tool_config": {
    "gdb": true,
    "frida": true,
    "ida": true,
    "ghidra": true,
    "z3": true,
    "angr": true,
    "pwntools": true,
    "ropgadget": true,
    "patch": true,
    "hook": true,
    "bruteforce": true,
    "symbolic_execution": true
  }
}
