    "C_pwn": ["06_injection", "07_memory_rw", "21_exploit_engineering", "28_process_injection", "32_container_k8s"],
    "D_assess": ["18_web_pentest", "19_internal_pentest", "20_privesc_persistence", "22_red_team_infra", "23_adcs_kerberos", "24_edr_bypass", "27_anti_forensics"],
    "E_topic": ["15_game_cheat", "25_supply_chain", "26_web3_defi"],
