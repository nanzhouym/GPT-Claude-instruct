  "tool_patterns": {
    "static": ["ida", "ghidra", "r2", "binary_ninja"],
    "dynamic": ["gdb", "frida", "qiling", "unicorn"],
    "symbolic": ["angr", "triton", "z3"],
    "mobile_android": ["jadx", "apktool", "frida", "objection"],
    "mobile_ios": ["frida-ios-dump", "class-dump", "theos"],
    "deobfuscation": ["angr", "triton", "pattern_recognition"]
